{
  "expo": {
    "name": "RunPack",
    "slug": "runpack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "runpack",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.runpack.app"
    },
    "android": {
      "package": "com.runpack.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ],
      "expo-pedometer"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
